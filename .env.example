# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayPal (for invoice checking)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# Discord Bot (optional, for DM notifications)
DISCORD_BOT_TOKEN=your-discord-bot-token

# App
PUBLIC_APP_URL=http://localhost:5173

# Cron job authentication
CRON_SECRET=your-cron-secret-here

# Admin (server-only)
# Comma-separated Discord IDs that have super-admin access
ADMIN_DISCORD_IDS=your-discord-id-1,your-discord-id-2
# Optional: comma-separated Supabase UUIDs for emergency non-Discord admin access
ADMIN_EMERGENCY_UUIDS=
